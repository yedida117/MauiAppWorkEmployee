<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppWorkEmployee.Views.AddWorkPage2"
            xmlns:local="clr-namespace:MauiAppWorkEmployee.ViewModel"  >
   

        <!-- הגדרת ה-BindingContext של הדף -->
        <ContentPage.BindingContext>
            <local:AddWorkVm />
        </ContentPage.BindingContext>

        <VerticalStackLayout Padding="30" Spacing="15" HorizontalOptions="Center" VerticalOptions="Center">

            <Label Text="אנא בחר תאריך לפגישה:" FontSize="18" />

            <!-- קישור דו-כיווני אוטומטי של התאריך -->
            <DatePicker Date="{Binding WorkD}" 
                    MinimumDate="01/01/2026" />

            <Entry Placeholder="תיאור הפגישה" 
               Text="{Binding JobType}" />

        <Entry Placeholder="place" 
     Text="{Binding LocationW}" />


    


        <!-- כפתור שמפעיל את פקודת השמירה ל-Firebase -->
            <Button Text="שמור ב-Firebase" 
                Command="{Binding SaveToFirebaseCommand}" />

        </VerticalStackLayout>
    </ContentPage>

