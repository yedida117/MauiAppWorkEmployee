<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:MauiAppWorkEmployee.Models"
           xmlns:views="clr-namespace:MauiAppWorkEmployee.Views"
             x:Class="MauiAppWorkEmployee.Views.LoginPage">
    <ContentPage.Content>
        <StackLayout>
            <Label Text="Welcome to Login Page!"
                />

            <Entry x:Name="password" Text="password" Placeholder="enter your password to login "/>

            <Button Text="Login" Clicked="Login_Clicked"/>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>