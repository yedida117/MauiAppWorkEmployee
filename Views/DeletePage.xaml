<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppWorkEmployee.Views.DeletePage">
    <ContentPage.Content>
        <StackLayout>
            <Button
     x:Name="DeleteBtn"
     Text="delete action " 
     SemanticProperties.Hint="delete"
     Clicked="OnDeleteButtonClicked"
     HorizontalOptions="Fill" />

            <Button Text="חזור למסך הראשי"
        Clicked="OnBackToMainClicked"
        BackgroundColor="#2196F3"
        TextColor="White"
        CornerRadius="8"
        Margin="10" />

            <Button Text="התנתק מהמערכת"
        Clicked="OnLogoutClicked"
        BackgroundColor="#F44336"
        TextColor="White"
        CornerRadius="8"
        Margin="10" />
        </StackLayout>
    </ContentPage.Content>
</ContentPage>